    <script>
        // 平滑滾動並聚焦到訂購區塊
        function openPurchaseModal() {
            const section = document.getElementById('purchase-section');
            if (section) {
                section.scrollIntoView({ behavior: 'smooth' });
                // 讓第一個輸入框自動聚焦
                setTimeout(() => {
                    document.getElementById('cust_name').focus();
                }, 600);
            }
        }

        // 處理表單提交
        function handleFormSubmit(event) {
            event.preventDefault();
            
            // 獲取客戶填寫的欄位數值
            const name = document.getElementById('cust_name').value;
            const phone = document.getElementById('cust_phone').value;
            const lineId = document.getElementById('cust_line').value;
            const mushroom = document.getElementById('cust_mushroom').value;
            const qty = document.getElementById('cust_qty').value;
            const address = document.getElementById('cust_address').value;
            
            // 在瀏覽器控制台打印結果 (模擬將資料傳輸給後台資料庫)
            console.log("捕獲到新訂單意向資料:", {
                "姓名": name,
                "電話": phone,
                "LINE ID/Zalo": lineId,
                "品種": mushroom,
                "數量": qty,
                "地址": address,
                "自動貼標": "#高意圖轉化_首頁直達"
            });

            // 顯示成功提示
            const alertBox = document.getElementById('form-success-alert');
            alertBox.classList.remove('hidden');
            
            // 重置表單
            document.getElementById('mushroom-order-form').reset();
            
            // 6秒後自動隱藏提示
            setTimeout(() => {
                alertBox.classList.add('hidden');
            }, 6000);
        }

        // 營銷九堂課動態摺疊切換
        function toggleAccordion(id) {
            const content = document.getElementById(id);
            const icon = document.getElementById('icon-' + id);
            
            if (content.classList.contains('hidden')) {
                content.classList.remove('hidden');
                if(icon) icon.className = "fa-solid fa-chevron-up text-xs text-[#D4AF37]";
            } else {
                content.classList.add('hidden');
                if(icon) icon.className = "fa-solid fa-chevron-down text-xs text-[#D4AF37]";
            }
        }

        // LINE選單模擬器互動顯示
        function triggerMenu(name, action, tag) {
            const logBox = document.getElementById('log-box');
            logBox.style.opacity = 0;
            setTimeout(() => {
                logBox.innerHTML = `🎯 <strong>【${name}】</strong> 已觸發動作：<span class="text-white">${action}</span><br>🏷️ 後台已自動為客戶打上標籤：<span class="text-green-400 font-bold">${tag}</span>`;
                logBox.style.opacity = 1;
            }, 150);
        }
    </script>
